{
  "name": "@sbb-journey-companion/backend",
  "license": "MIT",
  "author": "Davide Mininni",
  "version": "0.0.1",
  "description": "Backend for the sbb-journey-companion app.",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "yarn clean",
    "build": "tsc --build",
    "start:prod": "node dist/server.js",
    "start": "tsx watch src/server.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "keywords": [
    "nodejs",
    "travel"
  ],
  "dependencies": {
    "@sbb-journey-companion/common": "0.0.1",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "^13.0.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bcryptjs": "3.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.13.3",
    "rimraf": "6.1.3",
    "tsx": "4.23.1"
  }
}
