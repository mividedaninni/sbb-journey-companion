{
  "name": "sbb-journey-companion",
  "license": "MIT",
  "author": "Davide Mininni",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-perfectionist": "5.10.0",
    "eslint-plugin-prettier": "5.5.6",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.9.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0"
  },
  "scripts": {
    "build:common": "yarn workspace @sbb-journey-companion/common build",
    "build:backend": "yarn workspace @sbb-journey-companion/backend build",
    "build:frontend": "yarn workspace @sbb-journey-companion/frontend build",
    "build": "yarn build:common && yarn build:backend && yarn build:frontend",
    "start:common": "yarn workspace @sbb-journey-companion/common start",
    "start:backend": "yarn workspace @sbb-journey-companion/backend start",
    "start:frontend": "yarn workspace @sbb-journey-companion/frontend start",
    "start": "run-p start:common start:backend start:frontend",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/frontend/**/*.{ts,html}": "yarn workspace @sbb-journey-companion/frontend lint:fix",
    "packages/backend/**/*.ts": "yarn workspace @sbb-journey-companion/backend lint:fix",
    "packages/common/**/*.ts": "yarn workspace @sbb-journey-companion/common lint:fix"
  }
}
